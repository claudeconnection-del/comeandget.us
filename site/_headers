# Cloudflare Pages security headers (honored by `wrangler pages dev` + deploy).
# The site has ZERO runtime dependencies — every script, style, and asset is
# self-hosted — so a tight `default-src 'self'` policy holds without breaking it.
# `style-src` allows 'unsafe-inline' only because the arcade paints colour via
# inline `<span style>`; there are no inline <script>s or inline event handlers.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; form-action 'self'; base-uri 'none'; frame-ancestors 'none'; object-src 'none'; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin

# Byte Café — the "receipt-roll" challenge: a real custom response header on one
# artifact, so `curl -I` / DevTools Network reveals it (value is base64 of the flag).
/cafe/artifacts/receipt.txt
  Cache-Control: no-store
  X-Cafe-Receipt: Y2FmZXtyZWFkX2JldHdlZW5fdGhlX2hlYWRlcnN9
